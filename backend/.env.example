# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB — Use _dev suffix for development, _prod for production
# Development: /rupalsha_dev   Production: /rupalsha_prod
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rupalsha_dev?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@rupalsha.com
